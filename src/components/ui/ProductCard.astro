---
import { Image } from 'astro:assets';
import type { Product } from '../../data/products';

interface Props {
  product: Product;
}

const { product } = Astro.props;
---

<li
  data-card
  class="flex-shrink-0 flex flex-col"
  style="width: 280px; min-width: 280px; scroll-snap-align: start;"
>
  <!-- Product image -->
  <div
    class="overflow-hidden mb-6"
    style="height: 380px; background: var(--nox-muted);"
  >
    <Image
      src={product.imageUrl}
      alt={product.imageAlt}
      width={280}
      height={380}
      loading="lazy"
      decoding="async"
      class="w-full h-full object-cover transition-transform duration-700 hover:scale-105"
    />
  </div>

  <!-- Product info -->
  <div class="px-1">
    <h3
      class="text-display-md mb-2"
      style="color: var(--nox-fg); font-size: clamp(24px, 3vw, 36px);"
    >
      {product.name}
    </h3>
    <p
      class="text-label mb-4"
      style="color: var(--nox-fg); opacity: 0.5; text-transform: none; letter-spacing: 0.02em; font-weight: 400;"
    >
      {product.notes}
    </p>
    <p
      class="text-label"
      style="color: var(--nox-accent);"
    >
      {product.price}
    </p>
  </div>
</li>
