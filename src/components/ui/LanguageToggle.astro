---
import { getRelativeLocaleUrl } from 'astro:i18n';
import { isLocale } from '../../i18n/utils';

const currentLocale = isLocale(Astro.currentLocale) ? Astro.currentLocale : 'es';
const targetLocale = currentLocale === 'es' ? 'en' : 'es';
const targetLabel = currentLocale === 'es' ? 'EN' : 'ES';
const targetUrl = getRelativeLocaleUrl(targetLocale, '/');
---

<style>
  .language-toggle {
    font-family: var(--font-inter), sans-serif;
    font-size: 0.75rem;
    letter-spacing: 0.12em;
    color: var(--nox-fg);
    opacity: 0.75;
    text-transform: uppercase;
    text-decoration: none;
    padding: 0.375rem 0.625rem;
    border: 1px solid rgba(245, 230, 211, 0.25);
    background: rgba(26, 15, 10, 0.45);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
    border-radius: 2px;
    transition: opacity 0.2s ease;
  }

  @media (hover: hover) {
    .language-toggle:hover {
      opacity: 1;
    }
  }

  @media (max-width: 1023px) {
    .language-toggle {
      opacity: 0.9;
      font-size: 0.8125rem;
      padding: 0.5rem 0.875rem;
    }
  }
</style>

<a
  href={targetUrl}
  class="language-toggle"
  aria-label={`Switch to ${targetLocale === 'en' ? 'English' : 'Español'}`}
>
  {targetLabel}
</a>
