---
import { footerCopy } from '../../content/copy';
---

<footer
  class="py-8 px-6 border-t border-nox-muted"
  style="color: var(--nox-muted); font-family: var(--font-inter), system-ui, sans-serif; font-size: 12px;"
>
  <div class="max-w-7xl mx-auto flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
    <p>&copy; {new Date().getFullYear()} {footerCopy.brand}</p>
    <div class="flex flex-col sm:flex-row gap-2 sm:gap-6">
      <a
        href={footerCopy.unsplashUrl}
        target="_blank"
        rel="noopener noreferrer"
        style="color: var(--nox-muted); text-decoration: none;"
        class="hover:opacity-70 transition-opacity"
      >
        {footerCopy.photoCredit}
      </a>
      <span class="hidden sm:inline" aria-hidden="true">·</span>
      <a
        href="https://unsplash.com/@natecontrerasphoto"
        target="_blank"
        rel="noopener noreferrer"
        style="color: var(--nox-muted); text-decoration: none;"
        class="hover:opacity-70 transition-opacity"
      >
        Nate Contreraas
      </a>
      <span class="hidden sm:inline" aria-hidden="true">·</span>
      <a
        href="https://unsplash.com/@brookelark"
        target="_blank"
        rel="noopener noreferrer"
        style="color: var(--nox-muted); text-decoration: none;"
        class="hover:opacity-70 transition-opacity"
      >
        Brooke Lark
      </a>
      <span class="hidden sm:inline" aria-hidden="true">·</span>
      <a
        href="https://unsplash.com/@nate_dumlao"
        target="_blank"
        rel="noopener noreferrer"
        style="color: var(--nox-muted); text-decoration: none;"
        class="hover:opacity-70 transition-opacity"
      >
        Nathan Dumlao
      </a>
    </div>
  </div>
</footer>
