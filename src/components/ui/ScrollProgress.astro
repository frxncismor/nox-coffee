---
// Scroll progress indicator — thin accent bar at top of viewport
---

<div
  id="scroll-progress"
  class="scroll-progress"
  aria-hidden="true"
></div>

<time
  id="nox-clock"
  aria-hidden="true"
  style="
    position: fixed;
    top: 1.75rem;
    left: 1.5rem;
    z-index: 9998;
    font-family: var(--font-inter), monospace;
    font-size: 10px;
    letter-spacing: 0.12em;
    color: var(--nox-fg);
    opacity: 0.3;
    transition: color 0.5s ease, opacity 0.3s ease;
  "
></time>
