---
import { Image } from 'astro:assets';
import { useTranslations, isLocale } from '../../i18n/utils';
import LanguageToggle from '../ui/LanguageToggle.astro';

const locale = isLocale(Astro.currentLocale) ? Astro.currentLocale : 'es';
const t = useTranslations(locale);

const chars = t.hero.brand.split('');
const heroImageUrl = 'https://images.unsplash.com/photo-1495474472287-4d71bcdd2085?w=1920&h=1080&fit=crop&q=85';
---

<section
  data-hero-section
  class="relative overflow-hidden"
  style="height: 100svh;"
  aria-label="Hero"
>
  <!-- Background image with parallax target -->
  <div
    data-hero-image
    class="absolute inset-0"
    style="will-change: transform;"
  >
    <Image
      src={heroImageUrl}
      alt="Dark moody coffee atmosphere — las horas que importan"
      width={1920}
      height={1080}
      loading="eager"
      fetchpriority="high"
      decoding="async"
      class="w-full h-full object-cover"
      style="transform: scale(1.1);"
    />
  </div>

  <!-- Clock — scoped to hero, scrolls away with section -->
  <time
    id="nox-clock"
    aria-hidden="true"
    style="
      position: absolute;
      top: 1.75rem;
      left: 1.5rem;
      z-index: 50;
      font-family: var(--font-inter), monospace;
      font-size: 10px;
      letter-spacing: 0.12em;
      color: var(--nox-fg);
      opacity: 0.3;
      transition: color 0.5s ease, opacity 0.3s ease;
    "
  ></time>

  <!-- Language toggle — scoped to hero -->
  <div style="position: absolute; top: 1.25rem; right: 1.5rem; z-index: 50;">
    <LanguageToggle />
  </div>

  <!-- Dark gradient overlay -->
  <div
    class="absolute inset-0"
    style="background: linear-gradient(to bottom, rgba(26,15,10,0.7) 0%, transparent 40%, rgba(26,15,10,0.9) 100%);"
    aria-hidden="true"
  ></div>

  <!-- Hero content -->
  <div class="relative z-10 flex flex-col items-center justify-center h-full text-center px-6">
    <!-- NOX headline — each char wrapped for blur-in animation -->
    <h1
      class="text-display-xl"
      style="color: var(--nox-fg); letter-spacing: -0.04em; line-height: 0.85;"
      aria-label={t.hero.brand}
    >
      {chars.map((char) => (
        <span data-hero-char class="inline-block" aria-hidden="true" style="opacity: 0;">{char}</span>
      ))}
    </h1>

    <!-- Tagline -->
    <p
      data-hero-tagline
      style="font-family: var(--font-inter), sans-serif; font-weight: 400; font-size: clamp(16px, 2vw, 24px); color: var(--nox-accent); opacity: 0; margin-top: 1.5rem;"
    >
      {t.hero.tagline}
    </p>

    <!-- Steam Easter Egg — barely visible, pure atmosphere -->
    <div
      aria-hidden="true"
      style="
        position: absolute;
        bottom: 12rem;
        left: 50%;
        transform: translateX(-50%);
        opacity: 0.18;
        pointer-events: none;
      "
    >
      <svg width="60" height="48" viewBox="0 0 60 48" fill="none" xmlns="http://www.w3.org/2000/svg">
        <style>
          @keyframes steam1 { 0%,100%{d:path("M10 40 Q8 30 10 20 Q12 10 10 0")} 50%{d:path("M10 40 Q14 30 10 20 Q6 10 10 0")} }
          @keyframes steam2 { 0%,100%{d:path("M30 40 Q28 28 30 18 Q32 8 30 0")} 50%{d:path("M30 40 Q34 28 30 18 Q26 8 30 0")} }
          @keyframes steam3 { 0%,100%{d:path("M50 40 Q48 30 50 20 Q52 10 50 0")} 50%{d:path("M50 40 Q54 30 50 20 Q46 10 50 0")} }
          .s1{animation:steam1 3s ease-in-out infinite}
          .s2{animation:steam2 3.5s ease-in-out infinite 0.5s}
          .s3{animation:steam3 4s ease-in-out infinite 1s}
        </style>
        <path class="s1" d="M10 40 Q8 30 10 20 Q12 10 10 0" stroke="#F5E6D3" stroke-width="1.5" stroke-linecap="round" fill="none"/>
        <path class="s2" d="M30 40 Q28 28 30 18 Q32 8 30 0" stroke="#F5E6D3" stroke-width="1.5" stroke-linecap="round" fill="none"/>
        <path class="s3" d="M50 40 Q48 30 50 20 Q52 10 50 0" stroke="#F5E6D3" stroke-width="1.5" stroke-linecap="round" fill="none"/>
      </svg>
    </div>

    <!-- Scroll cue — whispered, no arrows -->
    <div
      data-scroll-cue
      class="absolute bottom-8"
      aria-hidden="true"
      style="color: var(--nox-fg); opacity: 0.4;"
    >
      <p class="text-label" style="letter-spacing: 0.2em; text-transform: lowercase;">{t.hero.scrollCue}</p>
    </div>
  </div>
</section>
