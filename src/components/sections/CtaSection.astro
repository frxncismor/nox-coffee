---
import MagneticButton from '../islands/MagneticButton';
import Footer from '../ui/Footer.astro';
import { ctaCopy } from '../../content/copy';
---

<section
  data-section="cta"
  class="min-h-screen flex flex-col items-center justify-center px-6 py-32"
  style="background: var(--nox-bg);"
>
  <div class="text-center max-w-3xl w-full">
    <!-- Main CTA headline -->
    <h2
      class="cta-headline text-display-lg mb-8"
      style="color: var(--nox-fg);"
    >
      {ctaCopy.headline}
    </h2>

    <!-- Sub-headline -->
    <p
      class="cta-subhead text-body mb-16 max-w-md mx-auto"
      style="color: var(--nox-fg); opacity: 0.7;"
    >
      {ctaCopy.subHeadline}
    </p>

    <!-- Magnetic button — React island -->
    <MagneticButton
      client:only="react"
      label={ctaCopy.buttonLabel}
      href={ctaCopy.buttonHref}
    />
  </div>
</section>

<!-- Footer -->
<Footer />
