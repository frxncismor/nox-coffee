---
import { Image } from 'astro:assets';
import { useTranslations, isLocale } from '../../i18n/utils';

interface Props {
  bagImageUrl?: string;
  bagImageAlt?: string;
}

const {
  bagImageUrl = 'https://images.unsplash.com/photo-1509042239860-f550ce710b93?w=600&h=900&fit=crop&q=85',
  bagImageAlt = 'Nox Coffee bag — single-origin specialty roast',
} = Astro.props;

const locale = isLocale(Astro.currentLocale) ? Astro.currentLocale : 'es';
const t = useTranslations(locale);

const panels = [
  { id: 'origin', label: t.showcase.origin.label, body: t.showcase.origin.body },
  { id: 'roast', label: t.showcase.roast.label, body: t.showcase.roast.body },
  { id: 'ritual', label: t.showcase.ritual.label, body: t.showcase.ritual.body },
] as const;
---

<section
  data-showcase-section
  class="min-h-screen"
  style="background: var(--nox-bg);"
>
  <!-- Desktop: two-column grid — bag left, panels right -->
  <!-- Mobile: stacked vertically -->
  <div
    class="
      min-h-screen
      flex flex-col
      lg:grid lg:grid-cols-[40%_60%]
      lg:items-center
    "
  >
    <!-- Coffee bag image -->
    <div
      class="
        flex items-center justify-center
        py-16 px-8 lg:py-0
        lg:h-full
      "
    >
      <div style="will-change: transform;" class="w-full max-w-sm" data-showcase-bag>
        <Image
          src={bagImageUrl}
          alt={bagImageAlt}
          width={600}
          height={900}
          loading="lazy"
          decoding="async"
          class="w-full h-auto object-contain drop-shadow-2xl"
        />
      </div>
    </div>

    <!-- Panels container -->
    <div
      class="
        relative
        flex flex-col lg:block
        px-8 lg:px-16 py-16 lg:py-0
        lg:h-screen lg:flex lg:items-center
      "
    >
      {panels.map((panel, index) => (
        <div
          data-panel={panel.id}
          class={`
            lg:absolute lg:inset-x-0 lg:px-16 lg:flex lg:flex-col lg:justify-center lg:h-full
            mb-16 lg:mb-0
          `}
          style={index === 0 ? '' : 'opacity: 0;'}
        >
          <!-- Panel label — small caps, gold accent -->
          <p
            class="text-label mb-6"
            style="color: var(--nox-accent); font-variant: small-caps;"
          >
            {panel.label}
          </p>

          <!-- Panel body — \n converted to line breaks -->
          <div
            class="text-body max-w-xl"
            style="color: var(--nox-fg); opacity: 0.85;"
          >
            {panel.body.split('\n').map((line) => (
              <p style="margin-bottom: 0.75em;">{line}</p>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
