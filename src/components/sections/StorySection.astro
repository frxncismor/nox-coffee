---
import { copy } from '../../content/copy';

const allText = copy.story.blocks.map((b) => b.text.replace(/\n/g, ' ')).join(' ');
---

<section
  data-story-section
  class="min-h-screen lg:h-screen flex flex-col items-center justify-center px-6 py-32 lg:py-0 lg:overflow-hidden"
  aria-label={allText}
>
  <div class="max-w-3xl w-full relative lg:h-full">
    {copy.story.blocks.map((block, blockIndex) => (
      <div
        data-story-block
        class="lg:absolute lg:inset-0 lg:flex lg:flex-col lg:justify-center mb-16 lg:mb-0"
        aria-hidden="true"
        style={`opacity: ${blockIndex === 0 ? 1 : 0};`}
      >
        {block.text.split('\n').map((line) => (
          <p
            class="text-display-md leading-relaxed"
            style="color: var(--nox-fg);"
          >
            {line}
          </p>
        ))}
      </div>
    ))}

    <!-- Screen reader accessible version -->
    <p class="sr-only">{allText}</p>
  </div>
</section>
